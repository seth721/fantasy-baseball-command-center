# Copy this file to secrets.toml and fill in your values.
# On Streamlit Cloud: paste these values in App Settings → Secrets.
# NEVER commit secrets.toml to GitHub.

[espn]
league_id = 123456        # Your ESPN league ID (found in the URL)
year      = 2026          # Current season year
team_id   = 1             # Your team number within the league
espn_s2   = "AEBxxxxxxxx" # Your espn_s2 cookie value
swid      = "{XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}" # Your SWID cookie value
